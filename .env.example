# Postgres — generate with: openssl rand -hex 24
POSTGRES_PASSWORD=

# Database (Docker Compose default; password must match POSTGRES_PASSWORD)
DATABASE_URL=postgresql://hourline:<password>@db:5432/hourline

# When running app on host against Docker DB only:
# DATABASE_URL=postgresql://hourline:<password>@localhost:5434/hourline

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=

# Public URL of the app (no trailing slash)
AUTH_URL=http://localhost:3001

# Branding
APP_DISPLAY_NAME=Hourline

# Email (optional — required to send timesheets to employers)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=hourline@example.com
