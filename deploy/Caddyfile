# Hourline — copy to /etc/caddy/Caddyfile on the VPS.
#
# Canonical site: https://hourline.bagghu.com
#
# DNS (all → your VPS IP):
#   hourline.bagghu.com       A     <VPS IP>   (required)
#   hourline.bagghu.co.uk     A     <VPS IP>   (redirect only)
#   www.hourline.bagghu.com   CNAME hourline.bagghu.com   (optional)
#   www.hourline.bagghu.co.uk A or CNAME → VPS / .co.uk apex (optional)
#
# Production .env:
#   AUTH_URL=https://hourline.bagghu.com
#
# Reload: sudo systemctl reload caddy

hourline.bagghu.com {
	reverse_proxy localhost:3011
}

hourline.bagghu.co.uk, www.hourline.bagghu.com, www.hourline.bagghu.co.uk {
	redir https://hourline.bagghu.com{uri} permanent
}
