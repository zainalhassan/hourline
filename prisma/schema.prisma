generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum JobTitlePreset {
  FIELD_ENGINEER
  OFFICE_DESK
  CONSULTANT
  FREELANCER
}

enum PeriodStatus {
  DRAFT
  READY
  SENT
}

enum PayPeriodType {
  WEEKLY
  FORTNIGHTLY
  MONTHLY
}

enum PaydayMode {
  DAY_OF_MONTH
  LAST_WEEKDAY_OF_MONTH
}

enum PayTimingMode {
  PAY_IN_ARREARS
  PERIOD_CLOSES_ON
}

enum PeriodCloseMode {
  DAY_OF_MONTH
  DAYS_BEFORE_PAYDAY
}

model User {
  id       String  @id @default(cuid())
  name     String?
  email    String  @unique
  emailVerified DateTime?
  passwordHash  String?
  image    String?

  employerName   String?
  employerEmail  String?
  ccSelfOnSubmit Boolean @default(false)
  submitMessage  String?
  durationPresets Json?

  payPeriodType   PayPeriodType @default(WEEKLY)
  paydayMode      PaydayMode    @default(DAY_OF_MONTH)
  paydayOfWeek    Int           @default(5)
  paydayOfMonth   Int           @default(28)
  payPeriodAnchor DateTime?     @db.Date
  payTimingMode   PayTimingMode @default(PAY_IN_ARREARS)
  periodCloseMode PeriodCloseMode @default(DAY_OF_MONTH)
  periodCloseDayOfMonth Int @default(31)
  periodCloseDaysBeforePayday Int @default(0)

  onboardingCompletedAt DateTime?

  activePreset         JobTitlePreset @default(FIELD_ENGINEER)
  activeUserTemplateId String?

  userTemplates UserTimesheetTemplate[]
  periods       TimesheetPeriod[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserTimesheetTemplate {
  id          String         @id @default(cuid())
  userId      String
  name        String
  description String?
  forkedFrom  JobTitlePreset
  fieldConfig Json

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model TimesheetPeriod {
  id        String       @id @default(cuid())
  userId    String
  startDate DateTime     @db.Date
  endDate   DateTime     @db.Date
  status    PeriodStatus @default(DRAFT)

  presetUsed          JobTitlePreset?
  userTemplateId      String?
  fieldConfigSnapshot Json?

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries     TimeEntry[]
  submissions Submission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, startDate])
  @@index([userId, status])
}

model TimeEntry {
  id              String   @id @default(cuid())
  periodId        String
  entryDate       DateTime @db.Date
  durationMinutes Int      @default(0)
  mileage         Decimal? @db.Decimal(10, 2)
  metadata        Json?

  period TimesheetPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([periodId, entryDate])
}

model Submission {
  id             String   @id @default(cuid())
  periodId       String
  sentAt         DateTime @default(now())
  recipientEmail String
  recipientName  String?
  ccEmail        String?
  message        String?
  pdfStoragePath String?

  period TimesheetPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@index([periodId])
}
